# LLM Provider — use one of the two
OPENAI_API_KEY=sk-...
COHERE_API_KEY=...                  # optional alternative

# ChromaDB
CHROMA_PERSIST_PATH=./chroma_data

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./aura.db
# DATABASE_URL=postgresql://user:password@localhost:5432/aura

# Escalation webhooks (mock)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/MOCK/WEBHOOK/URL
PAGERDUTY_ROUTING_KEY=mock-routing-key

# AWS S3 (optional runbook storage)
AWS_BUCKET_NAME=aura-runbooks
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# App settings
BACKEND_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
